{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/universities.schema.json",
  "title": "Mainland China University Thesis LaTeX Template Collection",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "school_id",
      "school_name_zh",
      "school_name_en",
      "city",
      "province",
      "status",
      "notes",
      "templates"
    ],
    "properties": {
      "school_id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "school_name_zh": {
        "type": "string",
        "minLength": 1
      },
      "school_name_en": {
        "type": "string",
        "minLength": 1
      },
      "city": {
        "type": "string",
        "minLength": 1
      },
      "province": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "covered",
          "unverified",
          "archived"
        ]
      },
      "notes": {
        "type": "string"
      },
      "templates": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "repo",
            "url",
            "degree_types",
            "official_status",
            "maintenance_status",
            "last_verified",
            "evidence",
            "github_metrics"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "degree_types": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "undergraduate",
                  "master",
                  "doctoral",
                  "postdoc",
                  "proposal",
                  "unknown"
                ]
              }
            },
            "official_status": {
              "type": "string",
              "enum": [
                "official",
                "community",
                "unknown"
              ]
            },
            "maintenance_status": {
              "type": "string",
              "enum": [
                "active",
                "inactive",
                "archived",
                "unknown"
              ]
            },
            "last_verified": {
              "type": "string",
              "format": "date"
            },
            "evidence": {
              "type": "string",
              "minLength": 1
            },
            "github_metrics": {
              "type": "object",
              "required": [
                "stars",
                "last_commit_at",
                "last_synced_at"
              ],
              "properties": {
                "stars": {
                  "type": "integer",
                  "minimum": 0
                },
                "last_commit_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "last_synced_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
